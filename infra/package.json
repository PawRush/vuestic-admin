{
  "name": "infra",
  "version": "0.1.0",
  "bin": {
    "infra": "bin/infra.js"
  },
  "scripts": {
    "build": "tsc",
    "watch": "tsc -w",
    "test": "jest",
    "cdk": "cdk",
    "deploy": "npm run deploy:preview",
    "deploy:preview": "cdk deploy --all --require-approval never --progress events",
    "deploy:pipeline": "cdk deploy VuesticAdminPipelineStack --context codeConnectionArn=arn:aws:codeconnections:us-east-1:002255676568:connection/410abcef-5063-4f37-bc14-c33b97f2943e --context repositoryName=PawRush/vuestic-admin --context branchName=deploy-to-aws --require-approval never --progress events",
    "destroy": "cdk destroy --all",
    "destroy:pipeline": "cdk destroy VuesticAdminPipelineStack --context codeConnectionArn=arn:aws:codeconnections:us-east-1:002255676568:connection/410abcef-5063-4f37-bc14-c33b97f2943e",
    "synth": "cdk synth",
    "diff": "cdk diff"
  },
  "devDependencies": {
    "@types/jest": "^30",
    "@types/node": "^24.10.1",
    "aws-cdk": "2.1100.3",
    "jest": "^30",
    "ts-jest": "^29",
    "ts-node": "^10.9.2",
    "typescript": "~5.9.3"
  },
  "dependencies": {
    "@aws-solutions-constructs/aws-cloudfront-s3": "^2.97.0",
    "aws-cdk-lib": "^2.234.1",
    "constructs": "^10.4.4"
  }
}
